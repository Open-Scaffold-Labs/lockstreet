# ======================================================================
# Lock Street — environment variables
# Copy this file to .env.local for dev and set the same vars in Vercel
# Project Settings → Environment Variables for prod.
# ======================================================================

# -------- Clerk (auth) --------
# Create an application at https://dashboard.clerk.com, then copy keys here.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# -------- Stripe (subscriptions) --------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Create these three Price IDs in Stripe (Products) and paste them in:
#   Weekly  $19 / week
#   Monthly $59 / month   (mark as POPULAR in our UI)
#   Season  $199 / season (one-time or 12-month)
STRIPE_PRICE_WEEKLY=price_REPLACE_ME
STRIPE_PRICE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_SEASON=price_REPLACE_ME
# Create via: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# -------- Vercel KV (pick storage, subscription cache, push subs) --------
# Create a KV store in Vercel Storage → KV; these are auto-injected in prod.
KV_URL=redis://REPLACE_ME
KV_REST_API_URL=https://REPLACE_ME
KV_REST_API_TOKEN=REPLACE_ME
KV_REST_API_READ_ONLY_TOKEN=REPLACE_ME

# -------- Web Push (notifications) --------
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BREPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME
VAPID_SUBJECT=mailto:matt@openscaffoldlabs.com

# -------- Admin panel --------
# Fallback gate for the admin route until a Clerk "admin" role is configured.
# Also checked server-side on /api/picks writes.
ADMIN_PASSWORD=change-me-long-and-random

# -------- App --------
# Public base URL of the deployment (used in Stripe redirect URLs)
VITE_APP_URL=http://localhost:5173
APP_URL=http://localhost:5173
