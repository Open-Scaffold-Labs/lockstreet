# ======================================================================
# Lock Street - environment variables
# Copy this file to .env.local for dev and set the same vars in Vercel
# Project Settings -> Environment Variables for prod.
# ======================================================================

# -------- Supabase (auth + database + storage) --------
# Project Settings -> API in your Supabase dashboard
VITE_SUPABASE_URL=https://REPLACE_ME.supabase.co
VITE_SUPABASE_ANON_KEY=eyJREPLACE_ME

# Same values for server-side use (Vite only exposes VITE_*-prefixed to client)
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_ANON_KEY=eyJREPLACE_ME

# Server-only admin key. NEVER prefix with VITE_, NEVER commit to git.
# Found in Supabase Dashboard -> Settings -> API -> service_role key.
# Required for: Stripe webhook, push notification broadcast, admin pick writes.
SUPABASE_SERVICE_ROLE_KEY=eyJREPLACE_ME_NEVER_COMMIT

# -------- Stripe (subscriptions) --------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Create three Stripe Products + Prices and paste the Price IDs:
STRIPE_PRICE_WEEKLY=price_REPLACE_ME
STRIPE_PRICE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_SEASON=price_REPLACE_ME
# From: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# -------- Web Push (notifications) --------
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BREPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME
VAPID_SUBJECT=mailto:matt@lockstreet.app

# -------- Admin panel --------
# Fallback gate for admin actions until your Supabase user has app_metadata.role='admin'.
ADMIN_PASSWORD=change-me-long-and-random

# -------- Email (Resend) --------
# Sign up at https://resend.com (3,000/mo free, no card). Used for:
#   1. Discord invite delivery on Annual checkout (subscriber-only)
#   2. Weekly preview email broadcast to active subscribers (subscriber-only)
# Free users do NOT receive email blasts; only auth emails (Supabase confirmation, password reset).
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=Lock Street <picks@lockstreet.app>

# -------- Discord (Annual subscriber perk) --------
# Static Discord server invite URL. Set on the server you create at discord.com.
# Annual subscribers get this emailed automatically after checkout.
DISCORD_INVITE_URL=https://discord.gg/REPLACE_ME

# -------- App --------
VITE_APP_URL=http://localhost:5173
APP_URL=http://localhost:5173
