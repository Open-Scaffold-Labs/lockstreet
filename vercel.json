{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api|assets|sw.js|manifest.json|favicon.ico).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/stripe-webhook.js": { "maxDuration": 20 }
  }
}
